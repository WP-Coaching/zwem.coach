# Site URL
# Set this to your production domain for proper OpenGraph tags and SEO
# On Vercel, this is automatically set from VERCEL_URL if not specified
NEXT_PUBLIC_SITE_URL=https://www.zwem.coach

# OpenGraph Image
# Set this to the URL of your OpenGraph image for social media sharing (1200x630px recommended)
# If not set, defaults to /og-image.jpg from the public folder
NEXT_PUBLIC_OG_IMAGE_URL=https://www.zwem.coach/og-image.jpg

# Stripe Payment Links
# Sept-Nov period
NEXT_PUBLIC_STRIPE_SEPT_NOV_MONDAY_LINK=https://buy.stripe.com/your-sept-nov-monday-link
NEXT_PUBLIC_STRIPE_SEPT_NOV_WEDNESDAY_LINK=https://buy.stripe.com/your-sept-nov-wednesday-link

# Jan-Mrt period
NEXT_PUBLIC_STRIPE_JAN_MRT_MONDAY_LINK=https://buy.stripe.com/your-jan-mrt-monday-link
NEXT_PUBLIC_STRIPE_JAN_MRT_WEDNESDAY_LINK=https://buy.stripe.com/your-jan-mrt-wednesday-link

# Apr-Jun period
NEXT_PUBLIC_STRIPE_APR_JUN_MONDAY_LINK=https://buy.stripe.com/your-apr-jun-monday-link
NEXT_PUBLIC_STRIPE_APR_JUN_WEDNESDAY_LINK=https://buy.stripe.com/your-apr-jun-wednesday-link

# Hero Video Background
# Upload your video to a Storage service and add the MP4 URL here
# The component will automatically use both WebM and MP4 versions
NEXT_PUBLIC_HERO_VIDEO_URL=https://your-vercel-blob-url.vercel-storage.com/your-video.mp4

# Summer School Links
NEXT_PUBLIC_STRIPE_SUMMERSCHOOL_INDOOR_G1_LINK=https://buy.stripe.com/your-summerschool-indoor-g1-link
NEXT_PUBLIC_STRIPE_SUMMERSCHOOL_INDOOR_G2_LINK=https://buy.stripe.com/your-summerschool-indoor-g2-link
NEXT_PUBLIC_STRIPE_SUMMERSCHOOL_OPENWATER_G1_LINK=https://buy.stripe.com/your-summerschool-openwater-g1-link
NEXT_PUBLIC_STRIPE_SUMMERSCHOOL_OPENWATER_G2_LINK=https://buy.stripe.com/your-summerschool-openwater-g2-link
